{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Ad": {
      "title": "Luxury Listing",
      "description": "A high-end listing for exclusive assets.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Private Islands", "Superyachts", "Luxury Villas", "Exclusive Charters", "Bespoke Experiences"] },
        "location": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "deleted"] },
        "isPremium": { "type": "boolean" },
        "transactionType": { "type": "string", "enum": ["sale", "rent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "category", "authorId", "transactionType"]
    },
    "AmbassadorApplication": {
      "title": "Ambassador Application",
      "description": "Application to become a luxury brand ambassador.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "socialMedia": { "type": "string" },
        "experience": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email"]
    },
    "Inquiry": {
      "title": "Ad Inquiry",
      "description": "A private inquiry about a luxury asset.",
      "type": "object",
      "properties": {
        "adId": { "type": "string" },
        "adTitle": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adId", "senderEmail", "message"]
    },
    "Category": {
      "title": "Ad Category",
      "description": "Predefined categories for ads.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name"]
    },
    "Bot": {
      "title": "Aether Bot",
      "description": "Configuration and status for Aether AI bots.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["CEO", "Analyst", "Compliance", "Content Curation", "Marketing", "Logistics"] },
        "status": { "type": "string", "enum": ["active", "idle", "processing"] },
        "lastAction": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "A chat session between a buyer and a seller.",
      "type": "object",
      "properties": {
        "adId": { "type": "string" },
        "adTitle": { "type": "string" },
        "buyerId": { "type": "string" },
        "buyerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adId", "buyerId", "sellerId"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat session.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    },
    "MarketAnalysis": {
      "title": "Market Analysis",
      "description": "Global market analysis reports generated by Aether Analyst.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "trend": { "type": "string" },
        "demandScore": { "type": "number" },
        "recommendation": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "trend"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A booking or purchase record for an asset.",
      "type": "object",
      "properties": {
        "adId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adId", "buyerId", "sellerId", "totalPrice", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "All classified listings."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Available categories."
    },
    "/ambassadors/{applicationId}": {
      "schema": "AmbassadorApplication",
      "description": "Recruitment applications."
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Private inquiries for ads."
    },
    "/bots/{botId}": {
      "schema": "Bot",
      "description": "Aether AI bots."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a chat session."
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Reservations and purchases."
    },
    "/market_analysis/{analysisId}": {
      "schema": "MarketAnalysis",
      "description": "Market reports."
    }
  }
}
